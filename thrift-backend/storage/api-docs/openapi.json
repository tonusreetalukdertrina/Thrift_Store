  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter your JWT token from auth endpoints"
      }
    },
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "type": "object",
                "properties": {
                  "user_id": { "type": "string", "format": "uuid" },
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "phone": { "type": "string" },
                  "role": { "type": "string" },
                  "profile_photo_url": { "type": "string", "nullable": true }
                }
              },
              "token": { "type": "string" }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "errors": { "type": "array", "items": {} }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "token": { "type": "string" }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "errors": { "type": "array", "items": {} }
        }
      },
      "ProfileResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "user_id": { "type": "string", "format": "uuid" },
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" },
              "phone": { "type": "string" },
              "role": { "type": "string" },
              "profile_photo_url": { "type": "string", "nullable": true },
              "is_blocked": { "type": "boolean" },
              "created_at": { "type": "string", "format": "date-time" }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "errors": { "type": "array", "items": {} }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "order": { "type": "object" },
              "seller_contact": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "phone": { "type": "string" }
                }
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "errors": { "type": "array", "items": {} }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "data": { "nullable": true },
          "meta": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
