                  "category_id": { "type": "integer" },
                  "subcategory_id": { "type": "integer", "nullable": true },
                  "location": { "type": "string", "maxLength": 255 },
                  "images": { "type": "array", "items": { "type": "string", "format": "binary" }, "minItems": 3, "maxItems": 5 }
                }
