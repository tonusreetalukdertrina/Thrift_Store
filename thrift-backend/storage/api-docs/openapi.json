{
  "openapi": "3.1.0",
  "info": {
    "title": "Thrift Store API",
    "version": "2.0.0",
    "description": "C2C marketplace API. Users can list items for sale, express interest in listings, and manage sales. Payment via Stripe (listing fee)."
  },
  "servers": [
    {
      "url": "http://localhost:8000/api",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Register, login, logout, and refresh JWT tokens. These endpoints manage user identity."
    },
    {
      "name": "Profile",
      "description": "View and update your own profile, change password, or delete your account. Requires authentication."
    },
    {
      "name": "Listings",
      "description": "Create, browse, and manage listings. Any authenticated user can create a listing (draft), pay a listing fee to publish it, and manage its lifecycle. Buyers can browse active listings publicly and express interest."
    },
    {
      "name": "Sellers",
      "description": "Public seller profiles. View a seller's active listings, average rating, and reviews. No authentication required."
    },
    {
      "name": "Payments",
      "description": "Stripe-powered listing fee payments. Sellers create draft listings, then pay for them in batches via Stripe checkout. Each listing costs ~$0.42 (50 BDT equivalent)."
    },
    {
      "name": "Webhooks",
      "description": "Stripe webhook endpoint. Called by Stripe after payment events (completion, expiry). No auth — verified via Stripe signature."
    },
    {
      "name": "Reviews",
      "description": "Buyers can review a listing after it's marked as sold. Sellers can respond to reviews. One review per listing."
    },
    {
      "name": "Notifications",
      "description": "In-app notifications. Users receive notifications for interest, sales, admin actions, etc. Read and mark as read."
    },
    {
      "name": "Reports",
      "description": "Report a listing, review, or user for policy violations. Admins review and resolve reports."
    },
    {
      "name": "Admin",
      "description": "Admin-only endpoints. Manage users (block/unblock), listings (remove/restore), reviews, reports, categories, payments, and view platform stats and audit logs. Requires admin role."
    }
  ],
  "paths": {
    "/v1/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "phone", "password"],
                "properties": {
                  "name": { "type": "string", "maxLength": 255, "example": "John Doe" },
                  "email": { "type": "string", "format": "email", "example": "john@example.com" },
                  "phone": { "type": "string", "example": "+1234567890" },
                  "password": { "type": "string", "minLength": 8, "description": "Must contain uppercase, lowercase, a number, and a special character", "example": "Password1!" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Registration successful", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "422": { "description": "Validation failed" }
        }
      }
    },
    "/v1/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Log in with email and password",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "john@example.com" },
                  "password": { "type": "string", "example": "Password1!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "401": { "description": "Invalid email or password" },
          "403": { "description": "Account is blocked" }
        }
      }
    },
    "/v1/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Log out the current user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logged out successfully" }
        }
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Refresh JWT token",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Token refreshed" },
          "401": { "description": "Token refresh failed" }
        }
      }
    },
    "/v1/profile": {
      "get": {
        "tags": ["Profile"],
        "summary": "Get the authenticated user's profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Profile data" }
        }
      },
      "post": {
        "tags": ["Profile"],
        "summary": "Update profile (name, phone, profile photo)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "maxLength": 255 },
                  "phone": { "type": "string" },
                  "profile_photo": { "type": "string", "format": "binary", "description": "Image file (jpeg, png, webp, max 5MB)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Profile updated" }
        }
      },
      "delete": {
        "tags": ["Profile"],
        "summary": "Delete account (archives listings, anonymizes data)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": { "type": "string", "example": "Password1!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Account deleted successfully" },
          "422": { "description": "Password is incorrect" }
        }
      }
    },
    "/v1/profile/change-password": {
      "post": {
        "tags": ["Profile"],
        "summary": "Change the authenticated user's password",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["current_password", "new_password", "new_password_confirmation"],
                "properties": {
                  "current_password": { "type": "string", "example": "OldPass1!" },
                  "new_password": { "type": "string", "minLength": 6, "example": "NewPass2!" },
                  "new_password_confirmation": { "type": "string", "example": "NewPass2!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password changed successfully" },
          "422": { "description": "Current password is incorrect or validation failed" }
        }
      }
    },
    "/v1/listings": {
      "get": {
        "tags": ["Listings"],
        "summary": "List active listings with filters and search",
        "security": [],
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Full-text search query" },
          { "name": "category_id", "in": "query", "schema": { "type": "integer" }, "description": "Filter by category ID" },
          { "name": "min_price", "in": "query", "schema": { "type": "number" }, "description": "Minimum price filter" },
          { "name": "max_price", "in": "query", "schema": { "type": "number" }, "description": "Maximum price filter" },
          { "name": "condition", "in": "query", "schema": { "type": "string", "enum": ["New", "Like New", "Good", "Fair"] } },
          { "name": "location", "in": "query", "schema": { "type": "string" }, "description": "Location search" },
          { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["newest", "price_asc", "price_desc"], "default": "newest" } }
        ],
        "responses": {
          "200": { "description": "Paginated list of active listings" }
        }
      },
      "post": {
        "tags": ["Listings"],
        "summary": "Create a new listing (as draft)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["title", "description", "price", "condition", "category_id", "images"],
                "properties": {
                  "title": { "type": "string", "minLength": 5, "maxLength": 120, "example": "Vintage Leather Jacket" },
                  "description": { "type": "string", "minLength": 20, "maxLength": 2000 },
                  "price": { "type": "number", "minimum": 0.01, "example": 49.99 },
                  "condition": { "type": "string", "enum": ["New", "Like New", "Good", "Fair"] },
                  "category_id": { "type": "integer", "example": 1 },
                  "location": { "type": "string", "maxLength": 255, "example": "New York, NY" },
                  "images": { "type": "array", "items": { "type": "string", "format": "binary" }, "minItems": 3, "maxItems": 5 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Listing created as draft" },
          "403": { "description": "Administrators cannot create listings" }
        }
      }
    },
    "/v1/listings/{id}": {
      "get": {
        "tags": ["Listings"],
        "summary": "Get a single listing by ID",
        "security": [],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Listing details" },
          "404": { "description": "Listing not found" }
        }
      },
      "put": {
        "tags": ["Listings"],
        "summary": "Update a listing (seller only, draft or active)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "minLength": 5, "maxLength": 120 },
                  "description": { "type": "string", "minLength": 20, "maxLength": 2000 },
                  "price": { "type": "number", "minimum": 0.01 },
                  "condition": { "type": "string", "enum": ["New", "Like New", "Good", "Fair"] },
                  "category_id": { "type": "integer" },
                  "location": { "type": "string", "maxLength": 255 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Listing updated" },
          "404": { "description": "Listing not found or not owned" },
          "422": { "description": "Only draft or active listings can be edited" }
        }
      },
      "delete": {
        "tags": ["Listings"],
        "summary": "Archive a listing (seller only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Listing archived successfully" },
          "404": { "description": "Listing not found or not owned" }
        }
      }
    },
    "/v1/listings/{id}/status": {
      "patch": {
        "tags": ["Listings"],
        "summary": "Update listing status (interested/sold/active/archived)",
        "description": "Transitions: **active→interested** (buyer), **interested→sold** (seller), **interested→active** (buyer withdraws), **active/draft→archived** (seller/admin). Invalid transitions return 422.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["interested", "sold", "active", "archived"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Status updated" },
          "422": { "description": "Transition not allowed" },
          "404": { "description": "Listing not found" }
        }
      }
    },
    "/v1/categories": {
      "get": {
        "tags": ["Listings"],
        "summary": "List all active categories",
        "security": [],
        "responses": {
          "200": { "description": "List of categories" }
        }
      }
    },
    "/v1/my-listings": {
      "get": {
        "tags": ["Listings"],
        "summary": "Get the authenticated seller's listings",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["draft", "active", "interested", "sold", "archived"] }, "description": "Filter by status" }
        ],
        "responses": {
          "200": { "description": "Seller's listings" }
        }
      }
    },
    "/v1/sellers/{id}": {
      "get": {
        "tags": ["Sellers"],
        "summary": "Get a seller's public profile",
        "security": [],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Seller profile with active listings" },
          "404": { "description": "Seller not found" }
        }
      }
    },
    "/v1/sellers/{id}/reviews": {
      "get": {
        "tags": ["Sellers"],
        "summary": "Get a seller's reviews (public)",
        "security": [],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Paginated reviews with average rating" }
        }
      }
    },
    "/v1/payments": {
      "get": {
        "tags": ["Payments"],
        "summary": "Get the authenticated seller's payment receipts",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Grouped payment receipts" }
        }
      }
    },
    "/v1/payments/due": {
      "get": {
        "tags": ["Payments"],
        "summary": "Get the seller's outstanding listing fees",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Due payment info with draft listings" }
        }
      }
    },
    "/v1/payments/checkout": {
      "post": {
        "tags": ["Payments"],
        "summary": "Create a Stripe checkout session for listing fees",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["listing_ids"],
                "properties": {
                  "listing_ids": {
                    "type": "array",
                    "items": { "type": "string", "format": "uuid" },
                    "minItems": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Checkout URL created" },
          "422": { "description": "Some listings are already active / have paid payment" },
          "502": { "description": "Stripe error" }
        }
      }
    },
    "/v1/payments/verify": {
      "post": {
        "tags": ["Payments"],
        "summary": "Verify a Stripe session and activate listings",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["session_id"],
                "properties": {
                  "session_id": { "type": "string", "example": "cs_test_..." }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Listings activated" },
          "402": { "description": "Payment not completed yet" },
          "403": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/webhook/stripe": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Stripe webhook handler",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": { "description": "Webhook received" }
        }
      }
    },
    "/v1/reviews": {
      "post": {
        "tags": ["Reviews"],
        "summary": "Submit a review for a sold listing (buyer)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["listing_id", "rating"],
                "properties": {
                  "listing_id": { "type": "string", "format": "uuid" },
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "comment": { "type": "string", "maxLength": 2000, "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Review submitted successfully" },
          "403": { "description": "Listing not sold or not your purchase" },
          "422": { "description": "Already reviewed this listing" }
        }
      }
    },
    "/v1/reviews/{id}/respond": {
      "post": {
        "tags": ["Reviews"],
        "summary": "Seller responds to a review",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["response"],
                "properties": {
                  "response": { "type": "string", "maxLength": 1000 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Response added" },
          "404": { "description": "Review not found" },
          "422": { "description": "Already responded" }
        }
      }
    },
    "/v1/notifications": {
      "get": {
        "tags": ["Notifications"],
        "summary": "Get the authenticated user's notifications",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Paginated notifications with unread count" }
        }
      }
    },
    "/v1/notifications/read-all": {
      "patch": {
        "tags": ["Notifications"],
        "summary": "Mark all notifications as read",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "All notifications marked as read" }
        }
      }
    },
    "/v1/notifications/{id}/read": {
      "patch": {
        "tags": ["Notifications"],
        "summary": "Mark a single notification as read",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Marked as read" }
        }
      }
    },
    "/v1/reports": {
      "post": {
        "tags": ["Reports"],
        "summary": "Report a listing, review, or user",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["target_type", "target_id", "reason"],
                "properties": {
                  "target_type": { "type": "string", "enum": ["listing", "review", "user"] },
                  "target_id": { "type": "string", "format": "uuid" },
                  "reason": { "type": "string", "minLength": 10, "maxLength": 1000 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Report submitted" },
          "422": { "description": "Duplicate report or validation failed" }
        }
      }
    },
    "/v1/admin/stats": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get platform statistics",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Platform stats" }
        }
      }
    },
    "/v1/admin/audit-log": {
      "get": {
        "tags": ["Admin"],
        "summary": "List audit log entries",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "admin_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "action", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Paginated audit log" }
        }
      }
    },
    "/v1/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "List users with optional filters",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Search by name, email, or phone" },
          { "name": "role", "in": "query", "schema": { "type": "string" } },
          { "name": "is_blocked", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": { "description": "Paginated user list" }
        }
      }
    },
    "/v1/admin/users/{id}/block": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Block a user (archives their listings)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "User blocked and listings archived" },
          "403": { "description": "Cannot block another admin" },
          "404": { "description": "User not found" }
        }
      }
    },
    "/v1/admin/users/{id}/unblock": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Unblock a user",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "User unblocked successfully" },
          "404": { "description": "User not found" }
        }
      }
    },
    "/v1/admin/listings": {
      "get": {
        "tags": ["Admin"],
        "summary": "List all listings with filters",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Search by title" }
        ],
        "responses": {
          "200": { "description": "Paginated listing list" }
        }
      }
    },
    "/v1/admin/listings/{id}": {
      "delete": {
        "tags": ["Admin"],
        "summary": "Remove (archive) a listing",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Listing removed and seller notified" },
          "404": { "description": "Listing not found" }
        }
      }
    },
    "/v1/admin/listings/{id}/restore": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Restore an archived listing",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Listing restored successfully" },
          "404": { "description": "Listing not found" },
          "422": { "description": "Only archived listings can be restored" }
        }
      }
    },
    "/v1/admin/reviews/{id}": {
      "delete": {
        "tags": ["Admin"],
        "summary": "Remove a review",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
